# Database (used by Drizzle ORM and the Postgres pool)
DATABASE_URL=postgresql://linkhub:linkhub@localhost:5432/linkhub

# better-auth — generate a strong random string for production
# (e.g. `openssl rand -base64 32`)
BETTER_AUTH_SECRET=replace-me-with-a-strong-random-string
BETTER_AUTH_URL=http://localhost:3000
